# NEXT_PUBLIC_USDT_RAIL_MAINNET_ENABLED=false

# === Toncenter API keys (optional, for higher rate limits) ===

# TONCENTER_MAINNET_API_KEY=

# TONCENTER_TESTNET_API_KEY=



# === Operator wallet (signs admin/ops txs) ===

# Default: scripts fall back to "plx-deployer" wallet name if not set.

# Current testnet operator after 2026-05-20 rotation drill is plx-deployer-v2.

# PLX_DEPLOYER=plx-deployer-v2

# PLX_ADMIN=plx-deployer-v2

# PLX_CALLER=plx-deployer-v2



# === Distribution wallet addresses (only needed for fresh deploy-distribution run) ===

# PLX_TREASURY=

# PLX_LP=

# PLX_COMMUNITY=

# PLX_MARKETING=

# PLX_BENEFICIARY=



# === Vesting start (Unix timestamp); defaults to "now" if unset ===

# PLX_VESTING_START=



# === Existing minter (required for ops scripts after initial deploy) ===

# Current testnet minter:

# JETTON_MINTER_ADDRESS=kQAslxaUshiiqy5FrTbYHbBpjBgmcyTHB8vKKCemFKp508xV



# === Vesting contract address (for claim-vesting script) ===

# Current testnet vesting:

# PLX_VESTING_ADDRESS=kQDNPoiPbKXwjt4i9SqtBmvbUlMgWz1jCR7M5Uwjj5fI8t1l



# === Drop-admin safety phrase (only set when ready to PERMANENTLY renounce) ===

# PLX_CONFIRM_DROP_ADMIN=1

# === Toolkit / ops (lihat .cursor/PLATFORM-INTEGRATIONS.md + OPS-ACCESS.md) ===
#
# PENTING — tiga lapisan secrets (jangan dicampur agent):
#   1. File ini (.env)           = master lokal, gitignored
#   2. Railway Variables         = service plx-toolkit, project plx-token (API prod)
#   3. Cloudflare Pages env      = web prod (plx.foundation)
#
# git push api/** → master HANYA redeploy kode Railway — TIDAK sync DATABASE_URL.
# Setelah push API: curl https://api.plx.foundation/health/db harus "connected".
#
# DATABASE_URL=             # Neon Postgres — WAJIB juga di Railway Variables (bukan sqlite)
# NEXTAUTH_SECRET=          # Identik di Railway + Cloudflare Pages
# RAILWAY_TOKEN=            # Railway Account → Tokens (secret penuh; terdaftar di dashboard ≠ otomatis valid)
# CLOUDFLARE_API_TOKEN=     # biasanya User env Windows
# GitHub App (phalanx-foundation org bot — optional, replaces personal PAT for gh/git)
# GITHUB_APP_ID=
# GITHUB_CLIENT_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_ORG=phalanx-foundation
# GITHUB_APP_PRIVATE_KEY_PATH=C:\Users\User\.ssh\phalanx-foundation.private-key.pem
# Auth: powershell -File .scripts\ops\github-app-auth.ps1
#
# === Coming soon gate (Cloudflare Pages production) ===
# COMING_SOON_ENABLED=true
# COMING_SOON_ALLOWED_IPS=  # comma-separated IPv4/IPv6 dev IPs (cf-connecting-ip)

# Copy this file to .env for local config.
# Acton loads .env automatically.

# === Toncenter API keys (optional, for higher rate limits) ===
# TONCENTER_MAINNET_API_KEY=
# TONCENTER_TESTNET_API_KEY=

# === Operator wallet (signs admin/ops txs) ===
# Default: scripts fall back to "plx-deployer" wallet name if not set.
# Current testnet operator after 2026-05-20 rotation drill is plx-deployer-v2.
# PLX_DEPLOYER=plx-deployer-v2
# PLX_ADMIN=plx-deployer-v2
# PLX_CALLER=plx-deployer-v2

# === Distribution wallet addresses (only needed for fresh deploy-distribution run) ===
# PLX_TREASURY=
# PLX_LP=
# PLX_COMMUNITY=
# PLX_MARKETING=
# PLX_BENEFICIARY=

# === Vesting start (Unix timestamp); defaults to "now" if unset ===
# PLX_VESTING_START=

# === Existing minter (required for ops scripts after initial deploy) ===
# Current testnet minter:
# JETTON_MINTER_ADDRESS=kQAslxaUshiiqy5FrTbYHbBpjBgmcyTHB8vKKCemFKp508xV

# === Vesting contract address (for claim-vesting script) ===
# Current testnet vesting:
# PLX_VESTING_ADDRESS=kQDNPoiPbKXwjt4i9SqtBmvbUlMgWz1jCR7M5Uwjj5fI8t1l

# === Drop-admin safety phrase (only set when ready to PERMANENTLY renounce) ===
# PLX_CONFIRM_DROP_ADMIN=I_UNDERSTAND_THIS_IS_FOREVER
